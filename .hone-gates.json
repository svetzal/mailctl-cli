{
  "gates": [
    {
      "name": "typecheck",
      "command": "bunx tsc --noEmit",
      "required": true
    },
    {
      "name": "lint",
      "command": "bunx biome check src/ test/",
      "required": true
    },
    {
      "name": "test",
      "command": "bun test",
      "required": true
    },
    {
      "name": "build",
      "command": "bun build src/cli.js --compile --outfile=build/mailctl",
      "required": true
    },
    {
      "name": "audit",
      "command": "bun audit",
      "required": true
    }
  ]
}
